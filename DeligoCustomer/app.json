{
  "expo": {
    "name": "DeliGo",
    "slug": "DeligoCustomer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#DC3173",
    "splash": {
      "image": "./src/assets/splash-icon.png",
      "backgroundColor": "#DC3173",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "0398adbd-442d-4696-8cbe-ff9fadd087a2"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deligo.customer",
      "icon": "./src/assets/icon.png",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false,
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "NSPhotoLibraryUsageDescription": "Allow Deligo to access your photo library to select profile pictures.",
        "NSCameraUsageDescription": "Allow Deligo to access your camera to take profile pictures."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCZ1jixNYbSRM21Uq82a6KXNO_FSpLUwaQ"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#DC3173",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#DC3173",
      "barStyle": "light-content"
    },
    "android": {
      "package": "com.deligo.customer",
      "versionCode": 1,
      "icon": "./src/assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#DC3173"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "android.permission.USE_FULL_SCREEN_INTENT"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCZ1jixNYbSRM21Uq82a6KXNO_FSpLUwaQ"
        }
      },
      "googleServicesFile": "./google-services.json",
      "metaData": {
        "com.google.firebase.messaging.default_notification_channel_id": "deligo_notifications_channel",
        "com.google.firebase.messaging.default_notification_color": "@color/notification_icon_color"
      }
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#DC3173",
          "image": "./src/assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Deligo to use your location for order tracking and delivery."
        }
      ],
      "expo-font",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.deligo.customer",
          "enableGooglePay": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "allowBackup": false,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "2.0.21",
            "gradlePluginVersion": "8.6.0",
            "newArchEnabled": false
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/icon.png",
          "color": "#DC3173",
          "sounds": [
            "./src/assets/sounds/notification_sound.wav"
          ]
        }
      ],
      [
        "@react-native-firebase/app",
        {
          "android": {
            "googleServicesFile": "./google-services.json"
          }
        }
      ],
      "./plugins/withResolvedFirebaseIconColor.js",
      "@react-native-firebase/messaging",
      "expo-web-browser",
      "expo-audio"
    ]
  }
}
