{
  "expo": {
    "name": "DeligoCustomer",
    "slug": "DeligoCustomer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#DC3173",
    "splash": {
      "image": "./src/assets/splash-icon.png",
      "backgroundColor": "#DC3173",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "b53f15eb-427a-4d03-89b6-c99f067ef883"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deligo.customer",
      "icon": "./src/assets/icon.png",
      "config": {
        "googleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_API_KEY"
      }
    },
    "android": {
      "package": "com.deligo.customer",
      "versionCode": 1,
      "icon": "./src/assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#DC3173"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_ANDROID_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#DC3173",
          "image": "./src/assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Deligo to use your location for order tracking and delivery."
        }
      ],
      "expo-font"
    ]
  }
}
