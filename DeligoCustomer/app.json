{
  "expo": {
    "name": "DeligoCustomer",
    "slug": "DeligoCustomer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#DC3173",
    "splash": {
      "image": "./src/assets/splash-icon.png",
      "backgroundColor": "#DC3173",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "extra": {
      "eas": {
        "projectId": "ca0fe010-d9c5-4bd5-9c95-ca726a09506b"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deligo.customer",
      "icon": "./src/assets/icon.png",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false,
        "UIStatusBarStyle": "UIStatusBarStyleLightContent",
        "NSPhotoLibraryUsageDescription": "Allow Deligo to access your photo library to select profile pictures.",
        "NSCameraUsageDescription": "Allow Deligo to access your camera to take profile pictures."
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCZ1jixNYbSRM21Uq82a6KXNO_FSpLUwaQ"
      }
    },
    "androidStatusBar": {
      "backgroundColor": "#DC3173",
      "barStyle": "light-content"
    },
    "androidNavigationBar": {
      "backgroundColor": "#DC3173",
      "barStyle": "light-content"
    },
    "android": {
      "package": "com.deligo.customer",
      "versionCode": 1,
      "icon": "./src/assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#DC3173"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCZ1jixNYbSRM21Uq82a6KXNO_FSpLUwaQ"
        }
      }
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#DC3173",
          "image": "./src/assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Deligo to use your location for order tracking and delivery."
        }
      ],
      "expo-font",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.deligo.customer",
          "enableGooglePay": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "allowBackup": false
          }
        }
      ]
    ]
  }
}
