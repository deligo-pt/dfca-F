{
  "expo": {
    "name": "DeligoCustomer",
    "slug": "DeligoCustomer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icon.png",
    "userInterfaceStyle": "light",
    "backgroundColor": "#DC3173",
    "splash": {
      "image": "./src/assets/splash-icon.png",
      "backgroundColor": "#DC3173",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "platforms": ["ios", "android", "web"],
    "extra": {
      "eas": {
        "projectId": "b53f15eb-427a-4d03-89b6-c99f067ef883"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deligo.customer",
      "icon": "./src/assets/icon.png",
      "infoPlist": {
        "UIViewControllerBasedStatusBarAppearance": false,
        "UIStatusBarStyle": "UIStatusBarStyleLightContent"
      },
      "config": {
        "googleMapsApiKey": "AIzaSyCZ1jixNYbSRM21Uq82a6KXNO_FSpLUwaQ"
      }
    },
    "android": {
      "package": "com.deligo.customer",
      "versionCode": 1,
      "icon": "./src/assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/adaptive-icon.png",
        "backgroundColor": "#DC3173"
      },
      "statusBar": {
        "backgroundColor": "#DC3173",
        "barStyle": "light-content"
      },
      "navigationBar": {
        "backgroundColor": "#DC3173",
        "barStyle": "light-content"
      },
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCZ1jixNYbSRM21Uq82a6KXNO_FSpLUwaQ"
        }
      }
    },
    "web": {
      "favicon": "./src/assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#DC3173",
          "image": "./src/assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Deligo to use your location for order tracking and delivery."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow the app to access your photos to update your profile picture."
        }
      ]
    ]
  }
}
